  <script>
    // Scroll reveal
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); revealObserver.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // LLM bars + visibility score
    const barObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          document.querySelectorAll('.llm-bar-fill').forEach((bar, i) => {
            setTimeout(() => { bar.style.width = bar.dataset.width + '%'; }, i * 180);
          });
          animateCounter(document.getElementById('visScore'), 0, 71, 1600);
          barObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.3 });
    const llmBars = document.getElementById('llmBars');
    if (llmBars) barObserver.observe(llmBars);

    // Stat counters
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          document.querySelectorAll('.reveal-stat').forEach(el => {
            animateCounter(el, 0, parseInt(el.dataset.target), 1800, el.dataset.suffix || '%');
          });
          statObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    document.querySelectorAll('.stats-bar').forEach(el => statObserver.observe(el));

    function animateCounter(el, start, end, duration, suffix = '') {
      const startTime = performance.now();
      function update(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(start + (end - start) * eased) + suffix;
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    // Nav scroll
    window.addEventListener('scroll', () => {
      document.querySelector('nav').style.background = window.scrollY > 60
        ? 'rgba(10,10,10,0.95)' : 'rgba(10,10,10,0.7)';
    }, { passive: true });
  </script>

